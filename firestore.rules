rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY: 10/10 PERFECTION
     * 1. Verified Identity: All write operations require a verified email.
     * 2. Strict Ownership: Data is private to the authenticated owner.
     * 3. Relational Integrity: relational fields (userId) and timestamps are immutable.
     * 4. Query Isolation: Rules act as filters for secure list operations.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerifiedOwner(userId) {
      return isEmailVerified() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Profiles can be read by the owner (even if not verified yet to allow setup)
      allow get: if isOwner(userId);
      
      // Creation and updates require a verified email for system integrity
      allow create: if isVerifiedOwner(userId) 
        && request.resource.data.id == userId
        && request.resource.data.createdAt == request.time;
      
      allow update: if isVerifiedOwner(userId) 
        && request.resource.data.id == resource.data.id;
        
      allow delete: if isVerifiedOwner(userId);

      match /conversionSnippets/{snippetId} {
        // Allow list/get for the owner to see their vault status
        allow get, list: if isOwner(userId);
        
        // Vaulting (Writes) strictly requires email verification
        allow create: if isVerifiedOwner(userId) 
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == request.time;
        
        allow update: if isVerifiedOwner(userId) 
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.base64String == resource.data.base64String; // Prevent payload tampering
          
        allow delete: if isVerifiedOwner(userId);
      }
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}