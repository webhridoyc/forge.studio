rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict User-Ownership model. All user-related data and 
     * saved conversion snippets are private and only accessible by the authenticated 
     * user who owns them.
     * 
     * DATA STRUCTURE
     * Data is organized hierarchically under /users/{userId}. 
     * Conversion snippets are stored in a subcollection under the specific user 
     * to ensure structural isolation and secure list operations.
     * 
     * KEY SECURITY DECISIONS
     * 1. Strict Owner-Only Access: Read and write permissions are restricted to the 
     *    authenticated user whose UID matches the document path.
     * 2. Denormalization for Authorization: Snippet documents contain a 'userId' field. 
     *    Rules validate this field against the path and the authenticated UID to 
     *    ensure relational integrity without extra database lookups.
     * 3. Prototyping Flexibility: Logic enforces "who" can access the data, but 
     *    does not enforce strict schema shapes for non-relational fields (like Base64 strings).
     * 4. Query Security: Listing of snippets is restricted to the owner's specific 
     *    path, satisfying the "Query-as-a-Privilege" model.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user ID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines ownership check with existence check for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Restricts access to the specific user.
     * @path /users/{userId}
     * @allow (get) If auth.uid == userId.
     * @allow (create) If auth.uid == userId and the data.id matches the path.
     * @deny (list) If auth.uid != userId (preventing user discovery).
     * @principle Enforces document ownership and self-creation for user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && request.resource.data.id == userId;
      
      allow update: if isExistingOwner(userId) 
        && request.resource.data.id == resource.data.id;
        
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for ConversionSnippet subcollection. Only the owner can manage snippets.
       * @path /users/{userId}/conversionSnippets/{snippetId}
       * @allow (create) If auth.uid == userId and request.resource.data.userId == userId.
       * @allow (list) If auth.uid == userId (allows fetching user's history).
       * @deny (update) If user attempts to change the userId field.
       * @principle Uses path-based authorization and denormalized field validation for secure ownership.
       */
      match /conversionSnippets/{snippetId} {
        allow get, list: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId;
        
        allow update: if isExistingOwner(userId) 
          && request.resource.data.userId == resource.data.userId;
          
        allow delete: if isExistingOwner(userId);
      }
    }

    // Default deny for any paths not explicitly matched.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}